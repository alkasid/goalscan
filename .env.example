# .env — credenziali locali per betfair_sync.py sul Raspberry Pi.
# Copia questo file in .env (stessa directory) e compila i valori.
# Il .env vero e' ignorato da git (vedi .gitignore).

# Application Key registrata su https://developer.betfair.com
BETFAIR_APP_KEY=xxxxxxxxxxxxxxxxxxxx

# Username del conto Betfair (non e' l'email, e' lo username di login)
BETFAIR_USERNAME=your_betfair_username

# Password del conto Betfair
BETFAIR_PASSWORD=your_betfair_password

# Opzionale: dominio di login. Default "com".
# Usa "it" per betfair.it, "es" per spagna, "ro" per romania, "se" per svezia.
# BETFAIR_ENDPOINT=com
